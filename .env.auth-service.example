# ──────────────────────────────────────────────────────────────────
# phantom-auth  ·  Environment Variables
# ──────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
AUTH_HOST=0.0.0.0
AUTH_PORT=8443
AUTH_LOG_LEVEL=info

# ── Daemon Connection ────────────────────────────────────────────
AUTH_PROXY_URL=unix:///var/run/phantom/daemon.sock
AUTH_PROXY_TIMEOUT=30.0
AUTH_PROXY_MAX_BODY=67108864

# ── Storage ──────────────────────────────────────────────────────
AUTH_DB_DIR=/var/lib/phantom/auth
AUTH_SECRETS_DIR=/run/secrets

# ── Token Lifetime ───────────────────────────────────────────────
AUTH_TOKEN_LIFETIME=86400
AUTH_MFA_TOKEN_LIFETIME=120
AUTH_TOTP_SETUP_LIFETIME=300
AUTH_INACTIVITY_TIMEOUT=1800

# ── Rate Limiting (login endpoint) ───────────────────────────────
AUTH_RATE_LIMIT_WINDOW=60
AUTH_RATE_LIMIT_MAX=5
# Cloudflare API credentials for phantom-stream-tool.
#
# Setup:
#   1. Copy this file to `.env` in the same directory.
#   2. Fill in your values (see links below).
#   3. The `.env` file is git-ignored and will not be committed.
#
# API token: https://dash.cloudflare.com/profile/api-tokens
#   Use the "Cloudflare Stream" template (Account → Stream: Edit).
#
# Account ID: visible in the Cloudflare dashboard sidebar, or at:
#   https://dash.cloudflare.com (right column on the home screen).

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional — auto-populated on first successful upload/list.
# Looks like "customer-abc123xyz" and is extracted from playback URLs.
CLOUDFLARE_CUSTOMER_SUBDOMAIN=

# ──────────────────────────────────────────────────────────────────
# Development environment variables
# ──────────────────────────────────────────────────────────────────

COMPOSE="docker compose -f docker-compose-dev.yml"
DAEMON="daemon"
GATEWAY_PORT=9080
SECRETS_DIR="container-data/secrets/development"
DAEMON_IMAGE="phantom-daemon-dev:latest"
DAEMON_DOCKERFILE="dev.Dockerfile"
AUTH_IMAGE="phantom-auth:latest"
AUTH_DB_DIR="container-data/auth-db"
TLS_SUBJECT="/C=TR/ST=Istanbul/L=Istanbul/O=Phantom-WG/OU=Development/CN=localhost"
TLS_SAN="DNS:localhost,IP:127.0.0.1"

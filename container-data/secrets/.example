# ──────────────────────────────────────────────────────────────────
# phantom-daemon  ·  Secrets
# ──────────────────────────────────────────────────────────────────
#
# container-data/secrets/
# ├── .example                    ← this file (tracked)
# ├── production/                 ← gitignored, file-per-key
# │   ├── .gitkeep
# │   ├── wg_private_key
# │   ├── wg_public_key
# │   └── db_encryption_key
# └── development/                ← gitignored, file-per-key
#     ├── .gitkeep
#     ├── wg_private_key
#     ├── wg_public_key
#     └── db_encryption_key
#
# Docker secrets → /run/secrets/<name>
# ──────────────────────────────────────────────────────────────────